<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <title>DIGIY MARKET PRO — Ma fiche (Saly)</title>
  <meta name="theme-color" content="#061b14"/>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root{
      --bg:#061b14;
      --card:#0b2a1f;
      --line:rgba(255,255,255,.14);
      --text:#eafff1;
      --muted:rgba(234,255,241,.75);
      --ok:#22c55e;
      --warn:#f59e0b;
      --bad:#ef4444;
      --gold:#facc15;
      --chip:#0a3a2a;
      --radius:18px;
      --shadow:0 18px 50px rgba(0,0,0,.35);
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif}
    a{color:inherit}
    button,input{font:inherit}

    .wrap{max-width:1040px;margin:0 auto;padding:16px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow)}
    .top{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:center}
    h1{margin:0;font-size:18px;font-weight:1000}
    p{margin:8px 0 0;color:var(--muted);line-height:1.45}
    .hr{height:1px;background:var(--line);margin:14px 0}

    .status{
      padding:12px;border-radius:16px;border:1px solid var(--line);
      font-weight:1000;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;
    }
    .status.ok{border-color:rgba(34,197,94,.55)}
    .status.warn{border-color:rgba(245,158,11,.55)}
    .status.bad{border-color:rgba(239,68,68,.55)}

    .tag{font-size:12px;padding:6px 10px;border-radius:999px;border:1px solid var(--line);color:var(--muted)}
    .tag.ok{color:var(--ok);border-color:rgba(34,197,94,.45)}
    .tag.warn{color:var(--warn);border-color:rgba(245,158,11,.45)}
    .tag.bad{color:var(--bad);border-color:rgba(239,68,68,.45)}
    .tag.gold{color:var(--gold);border-color:rgba(250,204,21,.55)}

    .grid{display:grid;grid-template-columns:1.2fr .8fr;gap:12px}
    @media(max-width:900px){.grid{grid-template-columns:1fr}}

    .box{border:1px solid var(--line);border-radius:16px;padding:14px;background:rgba(0,0,0,.12)}
    .row{display:flex;gap:10px;flex-wrap:wrap}
    .row > *{flex:1;min-width:220px}
    .label{font-weight:1000;margin-bottom:6px}
    .input{
      width:100%;padding:12px;border-radius:14px;border:1px solid rgba(255,255,255,.12);
      background:rgba(0,0,0,.12);color:var(--text);font-size:15px;outline:none;
    }
    .input:focus{border-color:rgba(250,204,21,.55);box-shadow:0 0 0 3px rgba(250,204,21,.12)}
    .small{font-size:13px;color:var(--muted);line-height:1.38}
    .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace}

    .btnRow{display:flex;gap:10px;flex-wrap:wrap}
    .btn{
      flex:1;min-width:180px;min-height:52px;border-radius:16px;cursor:pointer;border:1px solid var(--line);
      background:transparent;color:var(--text);padding:12px 14px;font-weight:1000;
      display:inline-flex;align-items:center;justify-content:center;gap:10px;text-decoration:none;
    }
    .btn:disabled{opacity:.55;cursor:not-allowed}
    .btn.ok{border-color:rgba(34,197,94,.55)}
    .btn.warn{border-color:rgba(245,158,11,.55)}
    .btn.gold{border-color:rgba(250,204,21,.65)}
    .btn.bad{border-color:rgba(239,68,68,.55)}

    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{
      font-size:12px;padding:7px 10px;border-radius:999px;border:1px solid rgba(255,255,255,.14);
      color:rgba(234,255,241,.9);background:rgba(0,0,0,.10);white-space:nowrap;
    }
    .chip.ok{border-color:rgba(34,197,94,.35);color:#bfffe0}
    .chip.gold{border-color:rgba(250,204,21,.35);color:#fff6c8}

    .preview{border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.10);background:rgba(0,0,0,.18)}
    .preview .photo{height:220px;background:rgba(0,0,0,.25);border-bottom:1px solid rgba(255,255,255,.08)}
    .preview img{width:100%;height:100%;object-fit:cover;display:block}
    .preview .body{padding:12px}
    .preview .name{font-weight:1000;color:var(--gold);font-size:18px;line-height:1.2}
    .preview .meta{margin-top:6px;color:var(--muted);font-weight:900;font-size:13px}
    .preview .bio{margin-top:8px;color:rgba(234,255,241,.9);font-weight:850;font-size:14px;line-height:1.38}

    .notice{margin-top:10px;padding:12px;border-radius:14px;border:1px dashed rgba(250,204,21,.35);background:rgba(250,204,21,.08);color:#fff3c0}
    .footer{margin-top:14px;font-size:12px;color:var(--muted);text-align:center}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="top">
        <div>
          <h1>🛒 DIGIY MARKET PRO — Ma fiche (Saly)</h1>
          <p class="small">
            Tu remplis ta fiche → elle apparaît <b style="color:var(--ok)">direct</b> dans la vitrine <b>Saly</b> pendant <b>7 jours</b>.
            Après, tu passes en <b style="color:var(--gold)">Abonné</b> pour rester visible.
          </p>
        </div>
        <div class="chips">
          <span class="chip ok">Essai 7 jours</span>
          <span class="chip gold">0% commission</span>
          <span class="chip">Paiement direct</span>
        </div>
      </div>

      <div class="hr"></div>

      <div class="status warn" id="statusBox">
        <div id="statusText">⏳ Préparation…</div>
        <span class="tag warn" id="statusTag">EN COURS</span>
      </div>

      <div class="hr"></div>

      <div class="grid">
        <div class="box">
          <div class="row">
            <div>
              <div class="label">📞 Ton téléphone (digits)</div>
              <input id="phone" class="input" type="tel" placeholder="Ex: 221778765785" inputmode="numeric"/>
              <div class="small">Mets 221 + ton numéro, sans espaces, sans +.</div>
            </div>
            <div>
              <div class="label">🔗 Ton slug vitrine</div>
              <input id="slug" class="input" type="text" placeholder="Ex: chez-astou-saly"/>
              <div class="small">Conseil : termine par <b>-saly</b>. On nettoie automatiquement.</div>
              <div id="slugAuto" class="small" style="margin-top:6px;"></div>
            </div>
          </div>

          <div class="hr"></div>

          <div class="row">
            <div>
              <div class="label">🏪 Nom visible</div>
              <input id="name" class="input" type="text" placeholder="Ex: Astou Boutique Téranga"/>
            </div>
            <div>
              <div class="label">🏷️ Catégorie</div>
              <input id="category" class="input" type="text" placeholder="Ex: Linge de maison / Sacs / Couture"/>
            </div>
          </div>

          <div class="hr"></div>

          <div class="row">
            <div>
              <div class="label">📍 Ville</div>
              <input id="city" class="input" type="text" value="Saly"/>
              <div class="small">On garde un rail simple : une ville à la fois.</div>
            </div>
            <div>
              <div class="label">💬 WhatsApp (digits)</div>
              <input id="whatsapp" class="input" type="tel" placeholder="Ex: 221778765785" inputmode="numeric"/>
              <div class="small">Si vide, on reprend ton téléphone.</div>
            </div>
          </div>

          <div class="hr"></div>

          <div class="row">
            <div>
              <div class="label">🖼️ Photo (lien)</div>
              <input id="photo" class="input" type="url" placeholder="https://…"/>
              <div class="small">Tu peux mettre un lien image direct.</div>
            </div>
            <div>
              <div class="label">🏷️ Tags (virgules)</div>
              <input id="tags" class="input" type="text" placeholder="ex: linge, maison, couture, saly"/>
              <div class="small">On convertit en tableau automatiquement.</div>
            </div>
          </div>

          <div class="hr"></div>

          <div>
            <div class="label">📝 Bio simple</div>
            <input id="bio" class="input" type="text" placeholder="Ex: Linge premium, couture sur mesure, textile local."/>
          </div>

          <div class="hr"></div>

          <div class="row">
            <div>
              <div class="label">🏪 Badge</div>
              <input id="badge" class="input" type="text" value="🏪 PARTENAIRE"/>
            </div>
            <div>
              <div class="label">🏷️ Hub badge</div>
              <input id="hub_badge" class="input" type="text" value="🛒 MARKET SALY"/>
            </div>
          </div>

          <div class="hr"></div>

          <div class="row">
            <div>
              <div class="label">💰 Texte prix (option)</div>
              <input id="price_label" class="input" type="text" value="💰 Prix à discuter • WhatsApp direct"/>
            </div>
            <div>
              <div class="label">🔗 Fiche (option)</div>
              <input id="profile_url" class="input" type="url" placeholder="https://market.digiylyfe.com/…"/>
              <div class="small">Si vide, on met la vitrine market.</div>
            </div>
          </div>

          <div class="hr"></div>

          <div class="btnRow">
            <button class="btn ok" id="btnSave" type="button">💾 Enregistrer</button>
            <button class="btn warn" id="btnTrial" type="button">🚀 Publier 7 jours</button>
          </div>

          <div class="hr"></div>

          <div class="btnRow">
            <button class="btn gold" id="btnPay" type="button">💳 Passer en Abonné</button>
            <button class="btn bad" id="btnSupport" type="button">💬 Support WhatsApp</button>
          </div>

          <div class="hr"></div>

          <div class="btnRow">
            <button class="btn" id="btnOpenVitrine" type="button">🌍 Ouvrir la vitrine</button>
            <button class="btn" id="btnCopyLink" type="button">🔗 Copier mon lien</button>
          </div>

          <p class="small" id="hint" style="margin-top:10px;"></p>
        </div>

        <div class="box">
          <div class="label">👀 Aperçu vitrine</div>
          <div class="preview" style="margin-top:10px;">
            <div class="photo">
              <img id="prevImg" alt="Photo" src="https://images.unsplash.com/photo-1528690873152-4cbd29d2c9c8?auto=format&fit=crop&w=1200&q=80"/>
            </div>
            <div class="body">
              <div class="name" id="prevName">—</div>
              <div class="meta" id="prevMeta">—</div>
              <div class="bio" id="prevBio">—</div>
              <div class="chips" style="margin-top:10px;">
                <span class="chip" id="prevBadge">🏪 PARTENAIRE</span>
                <span class="chip ok" id="prevHub">🛒 MARKET SALY</span>
              </div>
            </div>
          </div>

          <div class="hr"></div>

          <div class="label">🔗 Liens</div>
          <div class="small" style="margin-top:8px;line-height:1.6;">
            Vitrine globale : <a style="color:#bfffe0" href="https://market.digiylyfe.com/" target="_blank" rel="noopener">market.digiylyfe.com</a><br/>
            Ma fiche publique : <span class="mono" id="myPublicLink">—</span><br/>
            Mon PRO : <span class="mono" id="myProLink">—</span>
          </div>

          <div class="hr"></div>

          <div class="notice small">
            Après paiement, ton accès PRO peut arriver avec <span class="mono">?sub=market-22177...</span>.
            Cette page accepte aussi <span class="mono">?slug=chez-astou-saly</span> pour ouvrir la fiche directement.
          </div>
        </div>
      </div>

      <div class="footer">
        DIGIY MARKET PRO — Saly • 0% commission • paiement direct au pro ♾️
      </div>
    </div>
  </div>

  <script>
  (function(){
    'use strict';

    const SUPABASE_URL = window.DIGIY_SUPABASE_URL || 'https://wesqmwjjtsefyjnluosj.supabase.co';
    const SUPABASE_ANON_KEY = window.DIGIY_SUPABASE_ANON_KEY || 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Indlc3Ftd2pqdHNlZnlqbmx1b3NqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjUxNzg4ODIsImV4cCI6MjA4MDc1NDg4Mn0.dZfYOc2iL2_wRYL3zExZFsFSBK6AbMeOid2LrIjcTdA';

    const SUPPORT_WA = '221771342889';
    const VITRINE_URL = 'https://market.digiylyfe.com/';
    const PRO_URL = 'https://pro-market.digiylyfe.com/';
    const ABOS_URL = 'https://commencer-a-payer.digiylyfe.com/';
    const MODULE = 'MARKET';
    const PLAN = 'standard';
    const AMOUNT = 12900;
    const CODE = '6';
    const TRIAL_DAYS = 7;
    const FORCE_CITY = 'Saly';
    const DRAFT_KEY = 'digiy_market_pro_draft_v2';

    if(!window.supabase){
      alert('Supabase non chargé.');
      return;
    }

    const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: { persistSession:false, autoRefreshToken:false, detectSessionInUrl:false }
    });

    const $ = (id) => document.getElementById(id);
    const qp = new URLSearchParams(location.search);

    const state = {
      loading:false,
      row:null,
      hasAccess:false,
      subSlug:''
    };

    function setStatus(text, tone, tag){
      const box = $('statusBox');
      const tg = $('statusTag');
      box.className = 'status ' + (tone || 'warn');
      tg.className = 'tag ' + (tone || 'warn');
      $('statusText').textContent = text || '';
      tg.textContent = tag || '—';
    }

    function setBusy(on){
      state.loading = !!on;
      ['btnSave','btnTrial','btnPay','btnSupport','btnOpenVitrine','btnCopyLink'].forEach(id => {
        if($(id)) $(id).disabled = !!on;
      });
    }

    function normPhone(v){
      return String(v || '').replace(/[^\d]/g, '').trim();
    }

    function stripAccents(v){
      return String(v || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function normSlug(v){
      return stripAccents(v)
        .toLowerCase()
        .trim()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
    }

    function safeStr(v, max){
      return String(v || '').trim().slice(0, max || 250);
    }

    function safeUrl(v, fallback){
      const s = String(v || '').trim();
      if(!s) return fallback || '';
      try{
        const u = new URL(s);
        return u.href;
      }catch(_){
        return fallback || '';
      }
    }

    function tagsToArr(csv){
      return String(csv || '')
        .split(',')
        .map(x => x.trim())
        .filter(Boolean)
        .slice(0, 20);
    }

    function nowPlusDays(days){
      return new Date(Date.now() + Number(days || 0) * 86400000).toISOString();
    }

    function defaultPhotoUrl(){
      return 'https://images.unsplash.com/photo-1528690873152-4cbd29d2c9c8?auto=format&fit=crop&w=1200&q=80';
    }

    function ensureCity(){
      $('city').value = FORCE_CITY;
    }

    function wa(msg){
      location.href = 'https://wa.me/' + SUPPORT_WA + '?text=' + encodeURIComponent(msg);
    }

    function buildPublicLink(profileSlug){
      const slug = normSlug(profileSlug);
      if(!slug) return '';
      const u = new URL(VITRINE_URL);
      u.searchParams.set('slug', slug);
      return u.toString();
    }

    function buildProLink(profileSlug){
      const slug = normSlug(profileSlug);
      if(!slug) return '';
      const u = new URL(PRO_URL);
      u.searchParams.set('slug', slug);
      return u.toString();
    }

    function buildAbosUrl(phoneDigits, profileSlug){
      const u = new URL(ABOS_URL);
      u.searchParams.set('module', MODULE);
      u.searchParams.set('plan', PLAN);
      u.searchParams.set('amount', String(AMOUNT));
      u.searchParams.set('code', CODE);
      u.searchParams.set('return', PRO_URL);
      if(phoneDigits) u.searchParams.set('phone', normPhone(phoneDigits));
      if(profileSlug) u.searchParams.set('pslug', normSlug(profileSlug));
      return u.toString();
    }

    function saveDraft(){
      const draft = {
        phone:$('phone').value,
        slug:$('slug').value,
        name:$('name').value,
        category:$('category').value,
        city:$('city').value,
        whatsapp:$('whatsapp').value,
        photo:$('photo').value,
        tags:$('tags').value,
        bio:$('bio').value,
        badge:$('badge').value,
        hub_badge:$('hub_badge').value,
        price_label:$('price_label').value,
        profile_url:$('profile_url').value
      };
      localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
    }

    function loadDraft(){
      try{
        const raw = localStorage.getItem(DRAFT_KEY);
        if(!raw) return;
        const d = JSON.parse(raw);
        ['phone','slug','name','category','city','whatsapp','photo','tags','bio','badge','hub_badge','price_label','profile_url'].forEach(id => {
          if(d[id] != null && $(id) && !$(id).value) $(id).value = d[id];
        });
      }catch(_){ }
    }

    function refreshLinks(){
      const slug = normSlug($('slug').value || '');
      $('myPublicLink').textContent = slug ? buildPublicLink(slug) : '—';
      $('myProLink').textContent = slug ? buildProLink(slug) : '—';
    }

    function refreshPreview(){
      const name = safeStr($('name').value, 60) || '—';
      const city = safeStr($('city').value, 30) || FORCE_CITY;
      const cat = safeStr($('category').value, 60) || '—';
      const bio = safeStr($('bio').value, 150) || '—';
      const badge = safeStr($('badge').value, 40) || '🏪 PARTENAIRE';
      const hub = safeStr($('hub_badge').value, 40) || '🛒 MARKET SALY';
      const photo = safeUrl($('photo').value, defaultPhotoUrl()) || defaultPhotoUrl();

      $('prevName').textContent = name;
      $('prevMeta').textContent = '📍 ' + city + '  •  🏷️ ' + cat;
      $('prevBio').textContent = bio;
      $('prevBadge').textContent = badge;
      $('prevHub').textContent = hub;
      $('prevImg').src = photo;
      refreshLinks();
      saveDraft();
    }

    $('prevImg').addEventListener('error', function(){
      this.src = defaultPhotoUrl();
    });

    function fillFormFromRow(r){
      $('slug').value = r.slug || $('slug').value || '';
      $('phone').value = r.phone || $('phone').value || '';
      $('name').value = r.display_name || '';
      $('category').value = r.category || '';
      $('city').value = r.city || FORCE_CITY;
      $('whatsapp').value = r.whatsapp || '';
      $('photo').value = r.photo_url || '';
      $('tags').value = Array.isArray(r.tags) ? r.tags.join(', ') : '';
      $('bio').value = r.bio || '';
      $('badge').value = r.badge || '🏪 PARTENAIRE';
      $('hub_badge').value = r.hub_badge || '🛒 MARKET SALY';
      $('price_label').value = r.price_label || '💰 Prix à discuter • WhatsApp direct';
      $('profile_url').value = r.profile_url || '';
      refreshPreview();
    }

    function readPayload(){
      const phone = normPhone($('phone').value);
      const slug = normSlug($('slug').value);
      const payload = {
        phone,
        slug,
        display_name: safeStr($('name').value, 60),
        category: safeStr($('category').value, 80),
        city: FORCE_CITY,
        whatsapp: normPhone($('whatsapp').value || phone),
        photo_url: safeUrl($('photo').value, defaultPhotoUrl()),
        tags: tagsToArr($('tags').value),
        bio: safeStr($('bio').value, 180),
        badge: safeStr($('badge').value, 40) || '🏪 PARTENAIRE',
        hub_badge: safeStr($('hub_badge').value, 40) || '🛒 MARKET SALY',
        price_label: safeStr($('price_label').value, 90) || '💰 Prix à discuter • WhatsApp direct',
        profile_url: safeUrl($('profile_url').value, buildPublicLink(slug) || VITRINE_URL),
        is_active: true
      };
      return { phone, slug, payload };
    }

    function validateBasics(obj){
      if(!obj.phone || obj.phone.length < 9) return 'Téléphone obligatoire.';
      if(!obj.slug || obj.slug.length < 3) return 'Slug obligatoire.';
      if(!obj.payload.display_name) return 'Nom obligatoire.';
      if(!obj.payload.category) return 'Catégorie obligatoire.';
      return '';
    }

    async function loadExistingBySlug(profileSlug){
      const { data, error } = await sb
        .from('digiy_market_public_profiles')
        .select('id,phone,slug,display_name,city,category,whatsapp,photo_url,profile_url,bio,tags,badge,hub_badge,price_label,is_published,trial_end,created_at')
        .eq('slug', profileSlug)
        .maybeSingle();
      if(error) throw error;
      return data || null;
    }

    async function upsertProfile(payload){
      const { data, error } = await sb
        .from('digiy_market_public_profiles')
        .upsert(payload, { onConflict:'slug' })
        .select('*')
        .single();
      if(error) throw error;
      return data;
    }

    async function checkAccessMarketByPhone(phoneDigits){
      if(!phoneDigits) return false;
      try{
        const { data, error } = await sb.rpc('digiy_has_access', { p_phone: phoneDigits, p_module: 'MARKET' });
        if(error) return false;
        return !!data;
      }catch(_){
        return false;
      }
    }

    async function resolvePhoneFromSubscriptionSlug(subSlug){
      if(!subSlug) return null;
      try{
        const { data, error } = await sb
          .from('digiy_subscriptions_public')
          .select('phone,module,slug')
          .eq('slug', subSlug)
          .maybeSingle();
        if(error) return null;
        return data && data.phone ? String(data.phone) : null;
      }catch(_){
        return null;
      }
    }

    async function refreshAccessState(){
      const phone = normPhone($('phone').value);
      if(!phone){
        state.hasAccess = false;
        $('hint').textContent = '📞 Mets ton téléphone pour vérifier l’abonnement.';
        $('btnPay').disabled = false;
        $('btnPay').textContent = '💳 Passer en Abonné';
        return;
      }

      const ok = await checkAccessMarketByPhone(phone);
      state.hasAccess = ok;

      if(ok){
        $('hint').innerHTML = '✅ <b>Abonnement MARKET actif</b>. Tu es tranquille.';
        $('btnPay').textContent = '✅ Abonnement actif';
        $('btnPay').disabled = true;
      }else{
        $('hint').innerHTML = '🟡 Tu es en <b>essai</b> ou non abonné. Après 7 jours, passe en <b>Abonné</b>.';
        $('btnPay').textContent = '💳 Passer en Abonné';
        $('btnPay').disabled = false;
      }
    }

    async function actionLoadOrInit(){
      setBusy(true);
      setStatus('🔎 Ouverture de ta fiche…', 'warn', 'PRO');

      ensureCity();
      loadDraft();

      let sub = normSlug(qp.get('sub') || '');
      const slugParam = normSlug(qp.get('slug') || '');
      const pslugParam = normSlug(qp.get('pslug') || '');
      const urlPhone = normPhone(qp.get('phone') || '');

      if(!sub && slugParam.startsWith('market-')) sub = slugParam;
      if(sub.startsWith('market-')) state.subSlug = sub;

      if(urlPhone) $('phone').value = urlPhone;
      if(pslugParam) $('slug').value = pslugParam;
      if(slugParam && !slugParam.startsWith('market-')) $('slug').value = slugParam;

      if(state.subSlug){
        const inferredPhone = await resolvePhoneFromSubscriptionSlug(state.subSlug);
        if(inferredPhone){
          $('phone').value = inferredPhone;
          $('slugAuto').textContent = '✅ Téléphone retrouvé via abonnement.';
        }else{
          $('slugAuto').textContent = '⚠️ Abonnement non résolu automatiquement.';
        }
      }

      refreshPreview();

      const profileSlug = normSlug($('slug').value || '');
      if(profileSlug && !profileSlug.startsWith('market-')){
        try{
          const row = await loadExistingBySlug(profileSlug);
          state.row = row;
          if(row){
            fillFormFromRow(row);
            setStatus('✅ Fiche trouvée. Tu peux modifier et republier.', 'ok', 'OK');
          }else{
            setStatus('📝 Nouvelle fiche. Remplis puis publie.', 'warn', 'NOUVEAU');
          }
        }catch(e){
          console.error(e);
          setStatus('⚠️ Impossible de charger la fiche. On peut quand même remplir et tester.', 'bad', 'ERREUR');
        }
      }else{
        setStatus('📝 Mets ton slug vitrine. Exemple : chez-astou-saly', 'warn', 'SLUG');
      }

      await refreshAccessState();
      setBusy(false);
    }

    async function actionSave(){
      const data = readPayload();
      const err = validateBasics(data);
      if(err){
        setStatus('⚠️ ' + err, 'warn', 'INFO');
        return;
      }

      setBusy(true);
      setStatus('💾 Enregistrement…', 'warn', 'SAVE');
      try{
        const row = await upsertProfile({
          ...data.payload,
          is_published:false,
          trial_end:null
        });
        state.row = row;
        setStatus('✅ Enregistré. Tu peux publier 7 jours.', 'ok', 'OK');
        await refreshAccessState();
      }catch(e){
        console.error(e);
        setStatus('❌ Save impossible. Vérifie RLS, colonnes ou contrainte unique sur slug.', 'bad', 'ERREUR');
      }finally{
        setBusy(false);
      }
    }

    async function actionPublishTrial(){
      const data = readPayload();
      const err = validateBasics(data);
      if(err){
        setStatus('⚠️ ' + err, 'warn', 'INFO');
        return;
      }

      setBusy(true);
      setStatus('🚀 Publication essai 7 jours…', 'warn', 'TRIAL');
      try{
        const row = await upsertProfile({
          ...data.payload,
          is_published:true,
          trial_end:nowPlusDays(TRIAL_DAYS)
        });
        state.row = row;
        setStatus('✅ Publié. Tu es visible dans la vitrine Saly.', 'ok', 'LIVE');
        $('hint').innerHTML = '🔥 Tu es visible tout de suite. Fin essai : <span class="mono">' + (row.trial_end || '') + '</span>';
        await refreshAccessState();
      }catch(e){
        console.error(e);
        setStatus('❌ Publication impossible. Vérifie RLS, colonnes ou policy.', 'bad', 'ERREUR');
      }finally{
        setBusy(false);
      }
    }

    function actionGoPay(){
      const data = readPayload();
      const err = validateBasics(data);
      if(err){
        setStatus('⚠️ ' + err, 'warn', 'INFO');
        return;
      }
      location.href = buildAbosUrl(data.phone, data.slug);
    }

    function actionSupport(){
      const phone = normPhone($('phone').value || '');
      const slug = normSlug($('slug').value || '');
      const msg = [
        'Salut DIGIY MARKET.',
        '',
        phone ? 'Téléphone: +' + phone : '',
        slug ? 'Slug vitrine: ' + slug : '',
        state.subSlug ? 'SubSlug: ' + state.subSlug : '',
        'Ville: Saly',
        'Je veux de l\'aide sur ma fiche / paiement.'
      ].filter(Boolean).join('\n');
      wa(msg);
    }

    function actionOpenVitrine(){
      const slug = normSlug($('slug').value || '');
      const url = slug ? buildPublicLink(slug) : VITRINE_URL;
      window.open(url, '_blank', 'noopener');
    }

    async function actionCopyLink(){
      const slug = normSlug($('slug').value || '');
      const url = slug ? buildPublicLink(slug) : VITRINE_URL;
      try{
        await navigator.clipboard.writeText(url);
        setStatus('✅ Lien copié.', 'ok', 'LIEN');
      }catch(_){
        setStatus('⚠️ Copie impossible sur ce navigateur.', 'warn', 'LIEN');
      }
    }

    $('btnSave').addEventListener('click', actionSave);
    $('btnTrial').addEventListener('click', actionPublishTrial);
    $('btnPay').addEventListener('click', actionGoPay);
    $('btnSupport').addEventListener('click', actionSupport);
    $('btnOpenVitrine').addEventListener('click', actionOpenVitrine);
    $('btnCopyLink').addEventListener('click', actionCopyLink);

    ['name','category','city','bio','badge','hub_badge','photo','tags','price_label','profile_url'].forEach(id => {
      $(id).addEventListener('input', refreshPreview);
    });

    $('slug').addEventListener('input', function(){
      this.value = normSlug(this.value);
      $('slugAuto').textContent = this.value ? 'Slug prêt : ' + this.value : '';
      refreshPreview();
    });

    $('phone').addEventListener('input', async function(){
      this.value = normPhone(this.value);
      saveDraft();
      await refreshAccessState();
    });

    $('whatsapp').addEventListener('input', function(){
      this.value = normPhone(this.value);
      saveDraft();
    });

    $('city').addEventListener('input', function(){
      this.value = FORCE_CITY;
      refreshPreview();
    });

    ensureCity();
    refreshPreview();
    setStatus('✅ Prêt. Remplis ta fiche.', 'ok', 'READY');
    actionLoadOrInit();
  })();
  </script>
</body>
</html>
